{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run createproj (compiled)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/cli.js",
      "args": [
        "--sdk", "C:/sdk4/sdk4",
        "--bsp", "KIT_PSE84_EVAL_EPC2",
        "--dest", "C:/sdk4/projects/new-app",
        "--app", "mtb-example-psoc-edge-wifi-scan"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "npm: build",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Run createproj (ts-node)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ts-node", "src/cli.ts"],
      "args": [
        "--sdk",
        "C:/sdk4/sdk4",
        "--bsp",
        "KIT_PSE84_EVAL_EPC2",
        "--dest",
        "C:/sdk4/projects/new-app"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
