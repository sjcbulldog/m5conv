{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "mtb3create: Debug current build",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": [
        "--bsps", "KIT_PSE84_EVAL_EPC2,KIT_PSE84_EVAL_EPC4,KIT_PSE84_AI",
        "--dest", "c:/mtb4/proj3",
        "--creator", "C:/users/butch/ModusToolbox/tools_3.8/project-creator/project-creator-cli.exe"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "mtb3create: Debug current build (--force)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": [
        "--bsps", "KIT_PSE84_EVAL_EPC2,KIT_PSE84_EVAL_createEPC4,KIT_PSE84_AI",
        "--dest", "c:/mtb4/proj3",
        "--creator", "C:/users/butch/ModusToolbox/tools_3.8/project-creator/project-creator-cli.exe",
        "--force"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "mtb3create: Help",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": [
        "--help"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
