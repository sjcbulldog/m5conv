{
  "name": "mtb3create",
  "version": "1.0.0",
  "description": "Create all ModusToolbox examples for BSPs",
  "main": "dist/index.js",
  "bin": {
    "mtb3create": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "pkg:win": "pkg . --targets node18-win-x64 --output ../bin/win11/mtb3create.exe",
    "pkg:mac": "pkg . --targets node18-macos-x64 --output ../bin/macos/mtb3create",
    "pkg:linux": "pkg . --targets node18-linux-x64 --output ../bin/linux/mtb3create",
    "pkg:all": "npm run pkg:win && npm run pkg:mac && npm run pkg:linux"
  },
  "keywords": [
    "modustoolbox",
    "cli",
    "bsp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.13.2",
    "pkg": "^5.8.0",
    "typescript": "^5.9.2"
  }
}
