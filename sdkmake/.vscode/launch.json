{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug CLI (ts-node)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "ts-node",
        "${workspaceFolder}/src/index.ts"
      ],
      "args": [
        "--force",
        "--input",
        "C:/sdk4/mtb4",
        "--bsps",
        "KIT_PSE84_EVAL_EPC2,KIT_PSE84_EVAL_EPC4,KIT_PSE84_AI",
        "--output",
        "C:/sdk4/sdk4"
      ],
      "cwd": "${workspaceFolder}",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Debug CLI (dist)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": [
        "--force",
        "--input",
        "C:/sdk4/mtb4",
        "--bsps",
        "KIT_PSE84_EVAL_EPC2,KIT_PSE84_EVAL_EPC4,KIT_PSE84_AI",
        "--output",
        "C:/sdk4/sdk4"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "npm: build",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    }
  ]
}
