{
  "name": "compass-asset-manifest-tool",
  "version": "1.0.0",
  "private": true,
  "description": "CLI to generate per-asset asset.json component manifests",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:assets": "node dist/index.js",
    "dev:generate:assets": "ts-node src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
