{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Generate Assets (built)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Generate Assets (built, custom SDK)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": ["--sdk", "${input:sdkDir}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Generate Assets (ts-node)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:generate:assets"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Generate Assets (ts-node, custom SDK)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:generate:assets", "--", "--sdk", "${input:sdkDir}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "sdkDir",
      "type": "promptString",
      "description": "SDK directory path (relative or absolute) containing assets/",
      "default": "."
    }
  ]
}
