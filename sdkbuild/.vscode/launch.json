{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SDK Builder",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/ts-node",
      "runtimeArgs": ["--project", "${workspaceFolder}/tsconfig.json"],
      "args": [
        "--force",
        "--input", "${workspaceFolder}/../projects/mtb5/projs.json",
        "--output", "${workspaceFolder}/../sdk"
      ],
      "program": "${workspaceFolder}/src/index.ts",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
      }
    }
  ]
}
