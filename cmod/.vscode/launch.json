{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMakeToIAR",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      "args" : [
        "--force", 
        "--target", "iar",
        "../projects/graphics5", 
        "../projects/cmakebuild", 
        "../projects/iar/graphics"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "name": "CMakeToEclipse",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      "args" : [
        "--force", 
        "--target", "eclipse",
        "../projects/mtb5/graphics5", 
        "../projects/cmakebuild", 
        "../projects/eclipse/graphics"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }    
  ]
}
