{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMakeToIARProject",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      "args" : [
        "--force", 
        "../projects/graphics5", 
        "../projects/cmakebuild", 
        "../projects/iarproj"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    }
  ]
}
