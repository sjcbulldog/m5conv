{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MTB->CMake",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/index.ts",
            "preLaunchTask": "npm: build",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "sourceMaps": true,
            "console": "integratedTerminal",
            "args": [
                "--cmake-only",
                "--target", "gcc",
                "--source", "${workspaceFolder}/../projects/mtb/${input:mtbProjectName}",
                "--dest", "${workspaceFolder}/../projects/mtb5/${input:mtbProjectName}",
            ]
        }
    ],
    "inputs": [
        {
            "id" : "mtbProjectName",
            "type" : "promptString",
            "description" : "Name of the project to convert",
            "default" : "graphics"
        }
    ]
}
