{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Test Edge One Example",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/index.js",
      "args": [
        "--limit=1",
        "--include=mtb-example-psoc-edge-wifi-scan",
        "--bsps=KIT_PSE84_AI,KIT_PSE84_EVAL_EPC2",
        "--mtbdir=C:/sdk/mtb",
        "--cmakedir=C:/sdk/cmake",
        "--status=C:/sdk/status.json",
        "--project-creator=C:/users/butch/ModusToolbox/tools_3.8/project-creator/project-creator-cli.exe",
        "--mtb2cmake=C:/m5conv/bin/mtb2cmake.exe",
        "--depends=C:/m5conv/conv/depends.json",
        "--logs=C:/sdk/logs"
      ],
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build",
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Run All Examples",
