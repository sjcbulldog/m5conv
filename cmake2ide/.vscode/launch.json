{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMake->IAR",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      "args" : [
        "--force", 
        "--input", "C:/mtb5/edge/${input:mtbProjectName}", 
        "--iar", "C:/iar/edge/${input:mtbProjectName}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
    },
    {
      "name": "CMake->Eclipse",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx"],
      "program": "${workspaceFolder}/src/index.ts",
      "args" : [
        "--force", 
        "--input", "C:/mtb5/edge/${input:mtbProjectName}", 
        "--eclipse", "C:/eclipse/edge/${input:mtbProjectName}"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"],
    }    
  ],
  "inputs": [
    {
        "id" : "mtbProjectName",
        "type" : "promptString",
        "description" : "Name of the project to convert",
        "default" : "graphics"
    }
  ]
}
