{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "MTB->CMake",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/index.ts",
            "preLaunchTask": "npm: build",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "sourceMaps": true,
            "console": "integratedTerminal",
            "args": [
                "--target", "gcc,iar,llvm,arm",
                "--depends", "${workspaceFolder}/depends.json",
                "--source", "c:/mtb4/proj3/KIT_PSE84_EVAL_EPC2/${input:mtbProjectName}",
                "--dest", "c:/mtb4/proj4/b1",
            ]
        }
    ],
    "inputs": [
        {   "id" : "bspName",
            "type" : "promptString",
            "description" : "The BSP name",
            "default" : "KIT_PSE84_EVAL_EPC2"
        },
        {
            "id" : "mtbProjectName",
            "type" : "promptString",
            "description" : "Name of the project to convert",
            "default" : "graphics"
        }
    ]
}
