// depends.json — ModusToolbox asset dependency database for mtb2cmake
//
// This file describes the include-directory export/import relationships between
// ModusToolbox middleware and BSP assets so that the converter can wire up
// CMake target_include_directories() calls without needing to run the
// ModusToolbox build system.
//
// Format: JSON array of asset entries.  Comments (// and /* */) are allowed.
//
// Each entry has the following fields:
//
//   "name"     (string, required)
//              The asset's library name, matching the directory name under
//              the libs/ or shared/libs/ tree (e.g. "core-lib", "freertos").
//
//   "exports"  (string[], required)
//              Subdirectory paths (relative to the asset root) that are added
//              to the PUBLIC include path for any target that imports this asset.
//
//   "imports"  (array, optional)
//              Other assets whose exported include directories this asset needs.
//              Each element is either:
//                - a plain string  — the name of another asset in this file, or
//                  one of the special tokens:
//                    "***BSP***"                  the board support package root
//                    "***BSP***/config/GeneratedSource"  BSP generated headers
//                    "***PROJECT***"              the application project root
//                - an object { "component": "<COMPONENT_FLAG>", "name": "<asset>" }
//                  which makes the import conditional on that COMPONENT_* define.
//
//   "includes" (string[], optional)
//              Extra subdirectory paths added to the PRIVATE include path of
//              this asset only (not propagated to importers).
//
//   "internal" (string[], optional)
//              Source subdirectories that contain toolchain-specific source
//              files (e.g. "source/TOOLCHAIN_GCC_ARM").  The converter adds
//              these to the asset's source glob list.
//
//   "excludes" (string[], optional)
//              Subdirectory or file paths to exclude from source globbing
//              (e.g. test harnesses, documentation generator sources).
//
