{
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug mtbsuite",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/src/index.ts",
            "preLaunchTask": "npm: build",
            "outFiles": ["${workspaceFolder}/dist/**/*.js"],
            "sourceMaps": true,
            "console": "integratedTerminal",
            "args": [
                "--bsps",      "${workspaceFolder}/bsplist.json",
                "--mtbprojs",  "${workspaceFolder}/../projects/mtbprojects",
                "--cmakeprojs","${workspaceFolder}/../projects/cmakeprojects",
                "--builddirs", "${workspaceFolder}/../projects/builddirs",
                "--logs",      "${workspaceFolder}/../projects/logs",
                "--mapping",   "${workspaceFolder}/../projects/mapping.json",
                "--summary",   "${workspaceFolder}/../projects/summary.txt",
                "--force"
            ]
        }
    ]
}
